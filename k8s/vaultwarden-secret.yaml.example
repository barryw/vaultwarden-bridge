apiVersion: v1
kind: Secret
metadata:
  name: vaultwarden-credentials
  namespace: vaultwarden-bridge
type: Opaque
stringData:
  BW_SERVER: "https://vault.lan"
  BW_EMAIL: "bridge-service@example.com"
  BW_PASSWORD: "your-master-password"
---
apiVersion: v1
kind: Secret
metadata:
  name: bridge-admin
  namespace: vaultwarden-bridge
type: Opaque
stringData:
  username: "admin"
  password: "your-admin-password"
